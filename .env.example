# ── Railway environment variables ────────────────────────────────
# Set these in Railway → Project → Variables

APP_ENV=production
LOG_LEVEL=INFO

# JWT secret — change this to a long random string in production
JWT_SECRET=change-me-in-production

# CORS — set to your Vercel URL to restrict access
CORS_ORIGINS=["https://<your-app>.vercel.app"]

# LLM provider: "stub" (offline default) or "gemini"
LLM_PROVIDER=stub
GEMINI_API_KEY=

# Supabase (optional — leave blank to use in-memory fallback)
SUPABASE_URL=
SUPABASE_KEY=

# Observability — leave blank on Railway (no Jaeger/Prometheus)
OTEL_EXPORTER_ENDPOINT=
METRICS_ENABLED=true
